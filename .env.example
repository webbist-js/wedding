# ── Database ──────────────────────────────────────────────────────────────
# Local dev uses a SQLite file. Production uses Turso (libsql).
#   Local:      file:./local.db
#   Production: libsql://<your-db>.turso.io  (+ DATABASE_AUTH_TOKEN below)
DATABASE_URL=file:./local.db
# Turso auth token (production only). Get it with: turso db tokens create <db>
DATABASE_AUTH_TOKEN=

# ── Auth ──────────────────────────────────────────────────────────────────
# Random secret that signs the dashboard session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
# Hash of the dashboard passcode. Generate with hashPasscode() in
# src/lib/server/auth.ts. Dev passcode is `tithe-barn-2027`.
ADMIN_PASSCODE_HASH=

# ── Site ────────────────────────────────────────────────────────────────────
# Public base URL — used for links in Slack messages and QR codes.
#   Local:      http://localhost:5173
#   Production: https://sherdley-bennett.wedding
PUBLIC_BASE_URL=http://localhost:5173

# ── Slack ───────────────────────────────────────────────────────────────────
# Incoming webhook for RSVP, timeline, appointment & supplier notifications to
# #wedding. https://api.slack.com/apps -> your app -> "Incoming Webhooks".
# Leave blank locally to disable notifications.
SLACK_WEBHOOK_URL=

# ── Cron ──────────────────────────────────────────────────────────────────────
# Shared secret protecting /api/cron/timeline-check. On Vercel, set this and
# Vercel Cron auto-sends `Authorization: Bearer $CRON_SECRET` (see vercel.json).
CRON_SECRET=

# ── Email (Resend) — used by the AI vendor flow (added in the AI phase) ─────────
# RESEND_API_KEY=
# RESEND_INBOUND_SECRET=   # verifies inbound-email webhooks from Resend

# ── AI (Anthropic Claude) — added in the AI phase ───────────────────────────────
# ANTHROPIC_API_KEY=
