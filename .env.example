DATABASE_URL=file:./local.db
SESSION_SECRET=
# Generated via hashPasscode() in src/lib/server/auth.ts. Dev passcode is `tithe-barn-2027`.
ADMIN_PASSCODE_HASH=
PUBLIC_BASE_URL=http://localhost:5173

# Slack webhook for RSVP & timeline notifications to the #wedding channel.
# Get one from: https://api.slack.com/apps → your app → "Incoming Webhooks"
# (activate, "Add New Webhook to Workspace", choose #wedding, copy the URL).
# Looks like: https://hooks.slack.com/services/T.../B.../xxxxxxxxxx
# Leave blank locally to disable notifications.
SLACK_WEBHOOK_URL=

# Optional shared secret protecting /api/cron/timeline-check from public hits.
# When set, external cron jobs must pass `Authorization: Bearer $CRON_SECRET`.
# The in-process scheduler (boots from hooks.server.ts) doesn't need this.
CRON_SECRET=
